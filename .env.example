# Environment variables — copy this file to `.env` and fill in your values.
# The .env file is gitignored and will NOT be committed.

# ── Database ──────────────────────────────────────────────────────────
# LOCAL DEV (file-based SQLite, no token needed):
DATABASE_URL="file:/home/z/my-project/db/custom.db"
# PRODUCTION (Turso — SQLite at the edge for Cloudflare):
# DATABASE_URL="libsql://your-db-name-your-org.turso.io"
# DATABASE_AUTH_TOKEN="<turso-access-token>"

# ── Public site URL (canonical URLs, sitemap, OpenGraph) ──────────────
NEXT_PUBLIC_SITE_URL="https://www.hakoautomobile.com"

# ── Email (Resend) — for lead confirmations & trade-desk notifications ──
# Optional in development (API routes log to console instead)
RESEND_API_KEY=""
ADMIN_EMAIL="CONTACT@hakoautomobile.com"
FROM_EMAIL="no-reply@hakoautomobile.com"

# ── Authentication (NextAuth.js v4) — for the admin dashboard ──
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://www.orientautoexport.com"

# ── Storage (Cloudinary OR AWS S3) — for vehicle/brand/catalog media ──
# Leave blank to use local /public images
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── WhatsApp Business — pre-filled message phone number (digits only) ──
NEXT_PUBLIC_WHATSAPP_NUMBER="213780442267"

# ── Cloudflare deployment (set these in the Cloudflare dashboard) ─────
# The Cloudflare Worker reads these as env vars / secrets:
#   DATABASE_URL             ← Turso libsql:// URL
#   DATABASE_AUTH_TOKEN      ← Turso access token
#   NEXT_PUBLIC_WHATSAPP_NUMBER
